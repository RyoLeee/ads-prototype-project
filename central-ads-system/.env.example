# ─────────────────────────────────────────
#  CENTRAL ADS SYSTEM — Environment Config
# ─────────────────────────────────────────

# Ports
ADS_SERVICE_PORT=3001
COMPANY_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003
GATEWAY_PORT=3000
ENGINE_CHECK_INTERVAL=10000   # ms between balance checks

# Database (SQLite via libsql — file per service, or share one)
DATABASE_URL=file:./central-ads.db

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (mock if not set)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_MOCK_MODE=true          # set false to use real Stripe

# Internal service URLs (used by gateway & engine)
ADS_SERVICE_URL=http://localhost:3001
COMPANY_SERVICE_URL=http://localhost:3002
PAYMENT_SERVICE_URL=http://localhost:3003

# Logging
LOG_LEVEL=info                 # debug | info | warn | error
